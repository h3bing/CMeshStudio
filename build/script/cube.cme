            "细分": 1
          }
        }
      },
      "script": "void generate() {\n  float size = cgeo_get_prop_float(\"大小\");\n  if (size <= 0) size = 1.0f;\n  \n  cgeo_clear_vertices();\n  cgeo_clear_indices();\n  \n  // 生成顶点和法向量\n  // 前面\n  cgeo_add_vertex(-size, -size, -size);\n  cgeo_set_normal(0.0f, 0.0f, -1.0f);\n  cgeo_add_vertex(size, -size, -size);\n  cgeo_set_normal(0.0f, 0.0f, -1.0f);\n  cgeo_add_vertex(size, size, -size);\n  cgeo_set_normal(0.0f, 0.0f, -1.0f);\n  cgeo_add_vertex(-size, size, -size);\n  cgeo_set_normal(0.0f, 0.0f, -1.0f);\n  \n  // 后面\n  cgeo_add_vertex(-size, -size, size);\n  cgeo_set_normal(0.0f, 0.0f, 1.0f);\n  cgeo_add_vertex(size, -size, size);\n  cgeo_set_normal(0.0f, 0.0f, 1.0f);\n  cgeo_add_vertex(size, size, size);\n  cgeo_set_normal(0.0f, 0.0f, 1.0f);\n  cgeo_add_vertex(-size, size, size);\n  cgeo_set_normal(0.0f, 0.0f, 1.0f);\n  \n  // 左面\n  cgeo_add_vertex(-size, -size, -size);\n  cgeo_set_normal(-1.0f, 0.0f, 0.0f);\n  cgeo_add_vertex(-size, size, -size);\n  cgeo_set_normal(-1.0f, 0.0f, 0.0f);\n  cgeo_add_vertex(-size, size, size);\n  cgeo_set_normal(-1.0f, 0.0f, 0.0f);\n  cgeo_add_vertex(-size, -size, size);\n  cgeo_set_normal(-1.0f, 0.0f, 0.0f);\n  \n  // 右面\n  cgeo_add_vertex(size, -size, -size);\n  cgeo_set_normal(1.0f, 0.0f, 0.0f);\n  cgeo_add_vertex(size, -size, size);\n  cgeo_set_normal(1.0f, 0.0f, 0.0f);\n  cgeo_add_vertex(size, size, size);\n  cgeo_set_normal(1.0f, 0.0f, 0.0f);\n  cgeo_add_vertex(size, size, -size);\n  cgeo_set_normal(1.0f, 0.0f, 0.0f);\n  \n  // 顶面\n  cgeo_add_vertex(-size, size, -size);\n  cgeo_set_normal(0.0f, 1.0f, 0.0f);\n  cgeo_add_vertex(size, size, -size);\n  cgeo_set_normal(0.0f, 1.0f, 0.0f);\n  cgeo_add_vertex(size, size, size);\n  cgeo_set_normal(0.0f, 1.0f, 0.0f);\n  cgeo_add_vertex(-size, size, size);\n  cgeo_set_normal(0.0f, 1.0f, 0.0f);\n  \n  // 底面\n  cgeo_add_vertex(-size, -size, -size);\n  cgeo_set_normal(0.0f, -1.0f, 0.0f);\n  cgeo_add_vertex(-size, -size, size);\n  cgeo_set_normal(0.0f, -1.0f, 0.0f);\n  cgeo_add_vertex(size, -size, size);\n  cgeo_set_normal(0.0f, -1.0f, 0.0f);\n  cgeo_add_vertex(size, -size, -size);\n  cgeo_set_normal(0.0f, -1.0f, 0.0f);\n  \n  // 正面 (z=-size)\n  cgeo_add_index(0); cgeo_add_index(1); cgeo_add_index(2);\n  cgeo_add_index(0); cgeo_add_index(2); cgeo_add_index(3);\n  \n  // 背面 (z=size)\n  cgeo_add_index(4); cgeo_add_index(5); cgeo_add_index(6);\n  cgeo_add_index(4); cgeo_add_index(6); cgeo_add_index(7);\n  \n  // 左面 (x=-size)\n  cgeo_add_index(8); cgeo_add_index(9); cgeo_add_index(10);\n  cgeo_add_index(8); cgeo_add_index(10); cgeo_add_index(11);\n  \n  // 右面 (x=size)\n  cgeo_add_index(12); cgeo_add_index(13); cgeo_add_index(14);\n  cgeo_add_index(12); cgeo_add_index(14); cgeo_add_index(15);\n  \n  // 顶面 (y=size)\n  cgeo_add_index(16); cgeo_add_index(17); cgeo_add_index(18);\n  cgeo_add_index(16); cgeo_add_index(18); cgeo_add_index(19);\n  \n  // 底面 (y=-size)\n  cgeo_add_index(20); cgeo_add_index(21); cgeo_add_index(22);\n  cgeo_add_index(20); cgeo_add_index(22); cgeo_add_index(23);\n}",
      "transform": [
        1.0, 0.0, 0.0, 0.0,
